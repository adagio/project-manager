---
import type { ClaudeProjectSummary } from '@/lib/types';

interface Props {
  data: ClaudeProjectSummary[];
  colors: Record<string, string>;
}

const { data, colors } = Astro.props;

const labels = data.map(d => d.projectName);
const values = data.map(d => d.promptCount);
const bgColors = data.map(d => colors[d.projectId] || '#94a3b8');

const chartData = JSON.stringify({
  labels,
  datasets: [{
    data: values,
    backgroundColor: bgColors,
    borderWidth: 0,
  }],
});
---

<div class="rounded-lg border p-4" style="background-color: var(--color-surface); border-color: var(--color-border);">
  <h2 class="text-sm font-semibold mb-3">Prompts por proyecto</h2>
  <div style="height: 280px;" class="flex items-center justify-center">
    <canvas id="claude-by-project-chart"></canvas>
  </div>
</div>

<script is:inline define:vars={{ chartData }}>
  import('https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js').then((module) => {
    const Chart = module.default || module.Chart || window.Chart;
    const ctx = document.getElementById('claude-by-project-chart');
    if (!ctx) return;

    const data = JSON.parse(chartData);

    new Chart(ctx, {
      type: 'doughnut',
      data: data,
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '55%',
        plugins: {
          legend: {
            position: 'right',
            labels: {
              color: '#94a3b8',
              font: { size: 11 },
              boxWidth: 12,
              boxHeight: 12,
              padding: 10,
            },
          },
          tooltip: {
            backgroundColor: '#1e293b',
            titleColor: '#f1f5f9',
            bodyColor: '#94a3b8',
            borderColor: '#334155',
            borderWidth: 1,
            callbacks: {
              label: function(item) {
                const total = item.dataset.data.reduce((a, b) => a + b, 0);
                const pct = ((item.raw / total) * 100).toFixed(1);
                return item.label + ': ' + item.raw + ' prompts (' + pct + '%)';
              },
            },
          },
        },
      },
    });
  });
</script>

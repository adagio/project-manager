---
import { formatDuration } from '@/lib/date-utils';

interface ProjectYearData {
  projectName: string;
  color: string;
  monthlyHours: number[]; // 12 values, index 0 = Jan
  totalHours: number;
}

interface Props {
  data: ProjectYearData[];
  year: number;
}

const { data, year } = Astro.props;

const monthLabels = ['Ene', 'Feb', 'Mar', 'Abr', 'May', 'Jun', 'Jul', 'Ago', 'Sep', 'Oct', 'Nov', 'Dic'];

const datasets = data.map(project => ({
  label: project.projectName,
  data: project.monthlyHours.map(h => Math.round(h * 100) / 100),
  backgroundColor: project.color,
  borderRadius: 3,
}));

const chartData = JSON.stringify({ labels: monthLabels, datasets });
---

<div class="rounded-lg border p-4" style="background-color: var(--color-surface); border-color: var(--color-border);">
  <h2 class="text-sm font-semibold mb-3">Tiempo por proyecto — {year}</h2>

  {data.length === 0 ? (
    <div class="py-8 text-center text-sm" style="color: var(--color-text-muted);">
      Sin datos para {year}
    </div>
  ) : (
    <div>
      <div style="height: 220px;">
        <canvas id="yearly-activity-chart"></canvas>
      </div>

      <!-- Summary table -->
      <div class="mt-4 overflow-x-auto">
        <table class="w-full text-xs">
          <thead>
            <tr class="border-b" style="border-color: var(--color-border);">
              <th class="text-left py-2 font-medium sticky left-0" style="color: var(--color-text-muted); background-color: var(--color-surface);">Proyecto</th>
              {monthLabels.map(m => (
                <th class="text-right py-2 font-medium px-1.5" style="color: var(--color-text-muted);">{m}</th>
              ))}
              <th class="text-right py-2 font-semibold px-1.5" style="color: var(--color-text);">Total</th>
            </tr>
          </thead>
          <tbody>
            {data.filter(p => p.totalHours > 0).sort((a, b) => b.totalHours - a.totalHours).map(project => (
              <tr class="border-b" style="border-color: var(--color-border);">
                <td class="py-1.5 flex items-center gap-2 sticky left-0" style="background-color: var(--color-surface);">
                  <span class="w-2 h-2 rounded-full shrink-0" style={`background-color: ${project.color};`}></span>
                  <span class="truncate">{project.projectName}</span>
                </td>
                {project.monthlyHours.map(h => (
                  <td class="text-right py-1.5 px-1.5 font-mono" style={`color: ${h > 0 ? 'var(--color-text-muted)' : 'var(--color-border)'};`}>
                    {h > 0 ? formatDuration(h * 3600) : '-'}
                  </td>
                ))}
                <td class="text-right py-1.5 px-1.5 font-mono font-semibold">
                  {formatDuration(project.totalHours * 3600)}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  )}
</div>

<script is:inline define:vars={{ chartData }}>
  import('https://cdn.jsdelivr.net/npm/chart.js@4/dist/chart.umd.min.js').then((module) => {
    const Chart = module.default || module.Chart || window.Chart;
    const ctx = document.getElementById('yearly-activity-chart');
    if (!ctx) return;

    const data = JSON.parse(chartData);
    if (data.datasets.every(ds => ds.data.every(v => v === 0))) return;

    new Chart(ctx, {
      type: 'bar',
      data: data,
      options: {
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          x: {
            stacked: true,
            ticks: { color: '#94a3b8', font: { size: 11 } },
            grid: { display: false },
          },
          y: {
            stacked: true,
            beginAtZero: true,
            title: { display: true, text: 'horas', color: '#94a3b8', font: { size: 10 } },
            ticks: { color: '#94a3b8', font: { size: 10 } },
            grid: { color: 'rgba(148, 163, 184, 0.1)' },
          },
        },
        plugins: {
          legend: {
            display: true,
            position: 'bottom',
            labels: { color: '#94a3b8', font: { size: 11 }, boxWidth: 12, boxHeight: 12, padding: 12 },
          },
          tooltip: {
            mode: 'index',
            intersect: false,
            backgroundColor: '#1e293b',
            titleColor: '#f1f5f9',
            bodyColor: '#94a3b8',
            borderColor: '#334155',
            borderWidth: 1,
            callbacks: {
              label: function(item) {
                if (item.raw === 0) return null;
                return item.dataset.label + ': ' + Number(item.raw).toFixed(1) + 'h';
              },
            },
          },
        },
      },
    });
  });
</script>

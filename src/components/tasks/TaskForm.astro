---
import type { Project } from '@/lib/types';
import {
  TASK_STATUSES,
  TASK_STATUS_LABELS,
  parseTags,
  type Task,
} from '@/lib/data/tasks';

interface Props {
  projects: Project[];
  task?: Task | null;
  defaultProjectId?: string;
  /** Where the form posts. Defaults to /api/tasks/create. */
  action?: string;
  /** Optional title shown above the form. */
  title?: string;
  /** Compact layout (used inline on lists / project pages). */
  compact?: boolean;
}

const {
  projects,
  task = null,
  defaultProjectId,
  action,
  title = task ? 'Editar tarea' : 'Nueva tarea',
  compact = false,
} = Astro.props;

const isEdit = !!task;
const formAction = action ?? (isEdit ? '/api/tasks/update' : '/api/tasks/create');
const tagsValue = task ? parseTags(task.tags).join(', ') : '';

const inputStyle = 'background-color: var(--color-surface-hover); color: var(--color-text); border: 1px solid var(--color-border);';
---

<div class="rounded-lg border" style="background-color: var(--color-surface); border-color: var(--color-border);">
  {!compact && (
    <div class="px-4 py-3 border-b" style="border-color: var(--color-border);">
      <h2 class="text-sm font-semibold">{title}</h2>
    </div>
  )}

  <form method="POST" action={formAction} class={compact ? 'p-3 space-y-2' : 'p-4 space-y-3'}>
    {isEdit && <input type="hidden" name="id" value={task!.id} />}

    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <div class="md:col-span-2">
        <label class="block text-xs mb-1" style="color: var(--color-text-muted);">Título *</label>
        <input
          type="text"
          name="title"
          required
          maxlength="200"
          value={task?.title ?? ''}
          placeholder="Implementar login con OAuth"
          class="w-full px-3 py-1.5 text-sm rounded"
          style={inputStyle}
        />
      </div>

      <div>
        <label class="block text-xs mb-1" style="color: var(--color-text-muted);">Proyecto *</label>
        <select name="projectId" required class="w-full px-3 py-1.5 text-sm rounded" style={inputStyle}>
          <option value="">— elegir —</option>
          {projects.map((p) => (
            <option value={p.id} selected={(task?.projectId ?? defaultProjectId) === p.id}>
              {p.name}
            </option>
          ))}
        </select>
      </div>

      <div>
        <label class="block text-xs mb-1" style="color: var(--color-text-muted);">Estado</label>
        <select name="status" class="w-full px-3 py-1.5 text-sm rounded" style={inputStyle}>
          {TASK_STATUSES.map((s) => (
            <option value={s} selected={(task?.status ?? 'backlog') === s}>
              {TASK_STATUS_LABELS[s]}
            </option>
          ))}
        </select>
      </div>

      <div>
        <label class="block text-xs mb-1" style="color: var(--color-text-muted);">Due date</label>
        <input
          type="date"
          name="dueDate"
          value={task?.dueDate ?? ''}
          class="w-full px-3 py-1.5 text-sm rounded"
          style={inputStyle}
        />
      </div>

      <div>
        <label class="block text-xs mb-1" style="color: var(--color-text-muted);">Estimate (horas)</label>
        <input
          type="number"
          name="estimateHours"
          min="0"
          max="99.99"
          step="0.25"
          value={task?.estimateHours ?? ''}
          placeholder="1.5"
          class="w-full px-3 py-1.5 text-sm rounded"
          style={inputStyle}
        />
      </div>

      <div class="md:col-span-2">
        <label class="block text-xs mb-1" style="color: var(--color-text-muted);">
          Tags <span style="opacity: 0.6;">(separados por coma)</span>
        </label>
        <input
          type="text"
          name="tags"
          value={tagsValue}
          placeholder="bug, ui, urgent"
          class="w-full px-3 py-1.5 text-sm rounded"
          style={inputStyle}
        />
      </div>

      {!compact && (
        <div class="md:col-span-2">
          <label class="block text-xs mb-1" style="color: var(--color-text-muted);">Descripción</label>
          <textarea
            name="description"
            rows="3"
            placeholder="Notas, criterios de aceptación, links…"
            class="w-full px-3 py-1.5 text-sm rounded font-mono"
            style={inputStyle}
          >{task?.description ?? ''}</textarea>
        </div>
      )}
    </div>

    <div class="flex items-center gap-2 pt-1">
      <button
        type="submit"
        class="px-4 py-1.5 text-sm rounded font-medium transition-colors"
        style="background-color: var(--color-accent); color: var(--color-bg);"
      >
        {isEdit ? 'Guardar' : 'Crear tarea'}
      </button>
      {isEdit && (
        <a href="/tareas" class="px-3 py-1.5 text-sm rounded" style="color: var(--color-text-muted);">
          Cancelar
        </a>
      )}
    </div>
  </form>
</div>

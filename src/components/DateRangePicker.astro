---
import type { RangeKey } from '@/lib/date-utils';

interface Props {
  currentRange: RangeKey;
  basePath: string;
  offset?: number;
  label?: string;
}

const { currentRange, basePath, offset = 0, label } = Astro.props;

const options: { key: RangeKey; label: string }[] = [
  { key: 'today', label: 'Hoy' },
  { key: 'yesterday', label: 'Ayer' },
  { key: 'week', label: 'Semana' },
  { key: 'month', label: 'Mes' },
];

const canNavigate = currentRange === 'week' || currentRange === 'month' || currentRange === 'today';
const prevOffset = offset - 1;
const nextOffset = offset + 1;
const canGoNext = nextOffset <= 0;
---

<div class="flex items-center gap-3">
  <!-- Range selector -->
  <div class="flex gap-1.5">
    {options.map(opt => (
      <a
        href={`${basePath}?range=${opt.key}`}
        class={`px-3 py-1.5 text-sm rounded transition-colors ${currentRange === opt.key ? 'font-semibold' : ''}`}
        style={currentRange === opt.key
          ? `background-color: var(--color-accent); color: var(--color-bg);`
          : `background-color: var(--color-surface); color: var(--color-text-muted); border: 1px solid var(--color-border);`}
      >
        {opt.label}
      </a>
    ))}
  </div>

  <!-- Navigation arrows -->
  {canNavigate && (
    <div class="flex items-center gap-1">
      <a
        href={`${basePath}?range=${currentRange}&offset=${prevOffset}`}
        class="px-2 py-1 text-sm rounded transition-colors"
        style="background-color: var(--color-surface); color: var(--color-text-muted); border: 1px solid var(--color-border);"
      >
        &larr;
      </a>

      {label && offset !== 0 && (
        <span class="text-xs px-2" style="color: var(--color-text-muted);">{label}</span>
      )}

      {canGoNext ? (
        <a
          href={`${basePath}?range=${currentRange}&offset=${nextOffset}`}
          class="px-2 py-1 text-sm rounded transition-colors"
          style="background-color: var(--color-surface); color: var(--color-text-muted); border: 1px solid var(--color-border);"
        >
          &rarr;
        </a>
      ) : (
        <span class="px-2 py-1 text-sm rounded" style="color: var(--color-border);">&rarr;</span>
      )}
    </div>
  )}
</div>

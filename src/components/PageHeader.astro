---
interface Props {
  title: string;
  subtitle?: string;
  color?: string;
}

const { title, subtitle, color } = Astro.props;
---

<div class="px-6 py-4 border-b flex items-center gap-3" style="border-color: var(--color-border);">
  {color && <span class="w-3 h-3 rounded-full shrink-0" style={`background-color: ${color};`}></span>}
  <div>
    <h1 class="text-xl font-bold">{title}</h1>
    {subtitle && <p class="text-sm mt-0.5" style="color: var(--color-text-muted);">{subtitle}</p>}
  </div>
  <div class="ml-auto">
    <slot />
  </div>
</div>

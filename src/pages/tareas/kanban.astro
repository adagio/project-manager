---
export const prerender = false;

import Layout from '@/layouts/Layout.astro';
import PageHeader from '@/components/PageHeader.astro';
import KanbanBoard from '@/components/tasks/KanbanBoard.astro';
import TaskFilters from '@/components/tasks/TaskFilters.astro';
import { getProjects } from '@/lib/projects';
import { listTasks, TASK_STATUSES, type TaskStatus } from '@/lib/data/tasks';

const projects = getProjects();

const params = Astro.url.searchParams;
const selectedProject = params.get('project') ?? '';
const statusParam = params.get('status') ?? '';
const selectedStatus: TaskStatus | '' = (TASK_STATUSES as string[]).includes(statusParam)
  ? (statusParam as TaskStatus)
  : '';
const selectedTag = params.get('tag') ?? '';

const tasks = await listTasks({
  projectId: selectedProject || undefined,
  status: selectedStatus || undefined,
  tag: selectedTag || undefined,
});

const meta = `${tasks.length} tarea${tasks.length === 1 ? '' : 's'}`;

const listQs = new URLSearchParams();
if (selectedProject) listQs.set('project', selectedProject);
if (selectedStatus) listQs.set('status', selectedStatus);
if (selectedTag) listQs.set('tag', selectedTag);
const listHref = `/tareas${listQs.toString() ? `?${listQs}` : ''}`;
---

<Layout title="Kanban — Gestor de Proyectos">
  <PageHeader title="Tareas" subtitle="Vista Kanban">
    <a
      href={listHref}
      class="px-3 py-1.5 text-sm rounded font-medium"
      style="background-color: var(--color-surface); color: var(--color-text); border: 1px solid var(--color-border);"
    >
      ← Vista Lista
    </a>
  </PageHeader>

  <div class="p-6 space-y-4">
    <TaskFilters
      projects={projects}
      selectedProject={selectedProject}
      selectedStatus={selectedStatus}
      selectedTag={selectedTag}
      action="/tareas/kanban"
      meta={meta}
    />

    <KanbanBoard tasks={tasks} projects={projects} />
  </div>
</Layout>
